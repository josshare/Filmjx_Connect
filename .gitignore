# Flutter Version Management (https://fvm.app)
.fvm/

# Local env / secrets (keep examples tracked)
.env
.env.*
!.env.example

# Firebase CLI / FlutterFire (project id is local; use .firebaserc.example)
.firebaserc

# Firebase client configs (contienen API keys / ids de app; no subir a repos públicos)
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
macos/Runner/GoogleService-Info.plist
lib/firebase_options.dart

# Android / Gradle artefactos locales
android/build/
android/.gradle/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
